# =================================================================
# AWS LAMBDA ENVIRONMENT VARIABLES TEMPLATE
# =================================================================
# Copy these keys into your AWS Lambda Configuration -> Environment Variables.
# DO NOT commit your actual values to version control.

# 1. AI Configuration
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# 2. Infrastructure Configuration
S3_BUCKET_NAME=risk-analysing-app-data
AWS_REGION=ap-south-1

# 3. Model Parameters (Optional overrides)
MODEL_NAME=gemini-2.5-flash-lite