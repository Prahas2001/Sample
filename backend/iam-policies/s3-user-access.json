{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Effect": "Allow",
			"Action": [
				"s3:ListBucket"
			],
			"Resource": [
				"arn:aws:s3:::risk-analysing-app-data"
			],
			"Condition": {
				"StringLike": {
					"s3:prefix": [
						"uploads/${cognito-identity.amazonaws.com:sub}/*"
					]
				}
			}
		},
		{
			"Effect": "Allow",
			"Action": [
				"s3:PutObject",
				"s3:GetObject",
				"s3:DeleteObject"
			],
			"Resource": [
				"arn:aws:s3:::risk-analysing-app-data/uploads/${cognito-identity.amazonaws.com:sub}/*"
			]
		}
	]
}
